<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xsi:type="MailApp">
  <Id>d2c3e4f5-b678-4a12-9c1d-e2f3a4b5c6d7</Id>
  <Version>1.0.0.5</Version>
  <ProviderName>CleanTek</ProviderName>
  <DefaultLocale>zh-TW</DefaultLocale>
  <DisplayName DefaultValue="CleanTek 會議室管理"/>
  <Description DefaultValue="查看會議室狀態並預約"/>
  
  <IconUrl DefaultValue="https://cleantekcr01.github.io/outlook-cr-app/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://cleantekcr01.github.io/outlook-cr-app/icon.png"/>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <FormSettings>
    <ItemEdit>
      <ItemType>Appointment</ItemType>
      <DesktopSettings>
        <SourceLocation DefaultValue="https://cleantekcr01.github.io/outlook-cr-app/index.html"/>
      </DesktopSettings>
    </ItemEdit>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>
  
  <AppDomains>
    <AppDomain>https://script.google.com</AppDomain>
    <AppDomain>https://script.googleusercontent.com</AppDomain>
  </AppDomains>
</OfficeApp>